<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>6th Grade Math Review</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #eceff1; display: flex; justify-content: center; padding: 40px; }
        .quiz-card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); width: 100%; max-width: 700px; text-align: center; }
        .score-box { color: #005088; font-weight: bold; font-size: 1.2rem; margin-bottom: 20px; text-align: right; }
        img { max-width: 100%; border: 1px solid #ddd; margin-bottom: 20px; border-radius: 8px; min-height: 200px; background: #f9f9f9; }
        input { width: 60%; padding: 12px; font-size: 18px; border: 2px solid #005088; border-radius: 8px; outline: none; }
        button { padding: 12px 25px; font-size: 18px; background: #005088; color: white; border: none; border-radius: 8px; cursor: pointer; margin-left: 10px; }
        button:disabled { background: #ccc !important; cursor: not-allowed; }
        #feedback { margin-top: 20px; font-weight: bold; min-height: 24px; line-height: 1.6; text-align: left; padding: 15px; background: #f0f4f7; border-radius: 8px; display: none; }
        .nav-btns { margin-top: 30px; display: flex; justify-content: space-between; }
        .rationale-text { font-weight: normal; color: #444; font-size: 0.95rem; display: block; margin-top: 5px; border-top: 1px solid #ccc; padding-top: 5px; }
    </style>
</head>
<body>

<div class="quiz-card">
    <div class="score-box" id="score">correct: 0 / 64</div>
    
    <div id="quiz-content">
        <img id="question-img" src="" alt="Question Image">
        <div>
            <input type="text" id="answer-input" placeholder="Enter answer...">
            <button id="submit-btn" onclick="checkAnswer()">Submit</button>
        </div>
        <div id="feedback"></div>
    </div>

    <div class="nav-btns">
        <button onclick="prevQ()" style="background:#607d8b">Previous</button>
        <span id="q-tracker">Question 1 of 64</span>
        <button onclick="nextQ()" style="background:#607d8b">Next</button>
    </div>
</div>

